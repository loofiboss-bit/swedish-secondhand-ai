{
  "name": "swedish-secondhand-ai",
  "private": true,
  "version": "1.0.0-beta.1",
  "description": "Desktop app for Swedish secondhand item valuation and listing templates",
  "author": "Loofi",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "electron:dev": "concurrently --kill-others-on-fail \"vite --strictPort\" \"wait-on tcp:5173 && electron .\"",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern release",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "test:e2e": "playwright test --config playwright.config.ts",
    "docs:screenshots": "playwright test --config playwright.screenshots.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build && npm run format:check",
    "validate:release": "npm run validate && npm run test:e2e && node scripts/validate-release.mjs",
    "sbom": "cyclonedx-npm --output-file release/swedish-secondhand-ai-sbom.cdx.json --output-format JSON --spec-version 1.6 --omit dev",
    "package:smoke": "node scripts/package-smoke.mjs",
    "checksums": "node scripts/generate-checksums.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "i18next": "^25.8.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^9.2.4",
    "electron": "^40.8.5",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.loofi.swedishsecondhandai",
    "productName": "Swedish Secondhand AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "artifactName": "Swedish-Secondhand-AI-${version}-linux-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Swedish-Secondhand-AI-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "Swedish-Secondhand-AI-${version}-windows-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Swedish Secondhand AI"
    }
  }
}
